{
  "inbounds": [
    {
      "port": 443,
      "protocol": "https-vpn",
      "settings": {},
      "streamSettings": {
        "network": "h2",
        "security": "tls",
        "tlsSettings": {
          "cipherSuites": "ko",
          "certificates": [
            {
              "certificateFile": "/path/to/cert.pem",
              "keyFile": "/path/to/key.pem"
            }
          ]
        }
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "settings": {}
    }
  ]
}
